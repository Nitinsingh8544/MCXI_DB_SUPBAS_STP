generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
} 

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  username  String   @unique
  avatar    String?
  role      Role     @default(BUYER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  streams Stream[]
  orders  Order[]
  bids    Bid[]
}

model Stream {
  id          String   @id @default(cuid())
  title       String
  description String?
  isLive      Boolean  @default(false)
  hostId      String
  host        User     @relation(fields: [hostId], references: [id])
  createdAt   DateTime @default(now())

  products Product[]
  bids     Bid[]
}

model Product {
  id          String   @id @default(cuid())
  title       String
  description String?
  price       Float
  imageUrl    String?
  streamId    String
  stream      Stream   @relation(fields: [streamId], references: [id])
  createdAt   DateTime @default(now())

  orders Order[]
}

model Bid {
  id        String   @id @default(cuid())
  amount    Float
  userId    String
  streamId  String
  user      User     @relation(fields: [userId], references: [id])
  stream    Stream   @relation(fields: [streamId], references: [id])
  createdAt DateTime @default(now())
}

model Order {
  id        String      @id @default(cuid())
  userId    String
  productId String
  user      User        @relation(fields: [userId], references: [id])
  product   Product     @relation(fields: [productId], references: [id])
  amount    Float
  status    OrderStatus @default(PENDING)
  createdAt DateTime    @default(now())
}

enum Role {
  BUYER
  SELLER
  ADMIN
}

enum OrderStatus {
  PENDING
  PAID
  SHIPPED
  DELIVERED
  CANCELLED
}